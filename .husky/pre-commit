#!/usr/bin/env sh

is_docker() {
  [ -f /.dockerenv ]
}

is_wsl() {
  grep -qEi "(Microsoft|WSL)" /proc/version 2>/dev/null
}

echo "→ [backend] pint"

if is_docker; then
  ./vendor/bin/pint || { echo "Falha na formatação (pint). Corrija antes de continuar."; exit 1; }
elif is_wsl; then
  docker exec travel_backend ./vendor/bin/pint || { echo "Falha na formatação (pint). Corrija antes de continuar."; exit 1; }
else
  echo "Ambiente não reconhecido (não é Docker nem WSL)."
  exit 1
fi

echo "→ [frontend] lint + format"

if is_docker; then
  npm run lint && npm run format || { echo "Falha no lint/format do frontend. Corrija antes de continuar."; exit 1; }
elif is_wsl; then
  docker exec travel_frontend npm run lint && docker exec travel_frontend npm run format || { echo "Falha no lint/format do frontend. Corrija antes de continuar."; exit 1; }
else
  echo "Ambiente não reconhecido (não é Docker nem WSL)."
  exit 1
fi

exit 0
